#: data/io.gitlab.adhami3310.Footage.metainfo.xml.in.in:48
msgid "Editing screen with default options"
msgstr "Editando tela com as opções padrão"

#: data/io.gitlab.adhami3310.Footage.metainfo.xml.in.in:68
msgid "Fixes crash when framerate is undefined."
msgstr "Corrige falha quando a taxa de quadros é indefinida."

#: data/io.gitlab.adhami3310.Footage.metainfo.xml.in.in:73
msgid "Fixes various random crashes."
msgstr "Corrige várias falhas aleatórias."

#: data/io.gitlab.adhami3310.Footage.metainfo.xml.in.in:78
msgid "Fixes various bugs and upgrades to GNOME runtime 45."
msgstr "Corrige vários bugs e atualiza para o runtime do GNOME 45"

#: data/io.gitlab.adhami3310.Footage.metainfo.xml.in.in:83
msgid ""
"This minor release introduces a fix for X11 and additional translation "
"support."
msgstr ""
"Esta versão lançada introduz uma correção para o X11 e tradução adicional "
"suporte."

#: data/io.gitlab.adhami3310.Footage.metainfo.xml.in.in:88
msgid ""
"This minor release introduces a couple of bug fixes and enhances keyboard "
"accessibility."
msgstr ""
"Esta versão lançada introduz algumas correções de bugs e aprimora o teclado "
"acessibilidade."

#: data/io.gitlab.adhami3310.Footage.metainfo.xml.in.in:93
msgid "Initial version."
msgstr "Versão inicial."

